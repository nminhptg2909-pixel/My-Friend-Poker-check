{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ]
}
/* Styling cho biểu tượng hề */
.loss-icon {
  font-size: 1.2em; /* Điều chỉnh kích thước lớn hơn một chút */
  margin-right: 5px; /* Khoảng cách với số tiền */
  vertical-align: middle; /* Căn giữa theo chiều dọc */
  display: inline-block; /* Để áp dụng transform */
  animation: clownSpin 3s linear infinite; /* Thêm hiệu ứng xoay nhẹ liên tục */
}

/* Hiệu ứng xoay */
@keyframes clownSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
